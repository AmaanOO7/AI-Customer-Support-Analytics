# IBM Watsonx.ai Configuration
# Get your credentials from IBM Cloud: https://cloud.ibm.com/

# IBM Cloud API Key (Required)
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# Watsonx Project ID (Required)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx URL (Optional - defaults to US South region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model ID (Optional - defaults to Granite 13B Chat v2)
MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development
PORT=5000

# Application Settings
MAX_UPLOAD_SIZE_MB=20
MAX_WORKERS=5
